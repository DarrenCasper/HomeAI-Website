# "base" or "small" - balance of speed vs accuracy on modest hardware.
# "small" is meaningfully more accurate for a bit more CPU time per request.
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Only needed if running main.py directly outside the Dockerfile (which
# bakes this in via ARG PIPER_VOICE at build time and sets it automatically).
PIPER_VOICE_PATH=/models/en_US-lessac-medium.onnx
