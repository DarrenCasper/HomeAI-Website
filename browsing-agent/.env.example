# The browsing sub-agent's own LLM - OpenAI directly, not the local Ollama
# models used for normal chat (browser-use's tool-calling loop is most
# reliable against OpenAI models; gpt-4.1-mini is cheap enough to run
# per-task). Required - the app refuses to start without it.
OPENAI_API_KEY=
BROWSER_AGENT_MODEL=gpt-4.1-mini
BROWSER_AGENT_MAX_TOKENS=2048

# Three separate, nested timeouts - each needs headroom over the one it
# wraps (llm_timeout < step_timeout < BROWSER_AGENT_TIMEOUT_S), or the outer
# one becomes unreachable and silently overrides the inner one:
#   BROWSER_AGENT_LLM_TIMEOUT_S  - one LLM call
#   BROWSER_AGENT_STEP_TIMEOUT_S - that call + executing the resulting
#                                  browser action (browser-use defaults this
#                                  to 180s internally)
#   BROWSER_AGENT_TIMEOUT_S      - the whole /browse task: multiple steps,
#                                  each possibly retried up to 6x
BROWSER_AGENT_LLM_TIMEOUT_S=120
BROWSER_AGENT_STEP_TIMEOUT_S=180
BROWSER_AGENT_TIMEOUT_S=600

# Leave false: blocks navigation to literal IP addresses (covers RFC1918,
# loopback, 169.254.0.0/16) and to localhost/*.local/*.internal/*.lan/*.ts.net,
# so a prompt-injected page can't redirect the agent at this homelab or its
# tailnet. Only set true for deliberate local testing.
BROWSER_AGENT_ALLOW_PRIVATE_NET=false

# Node backend's own address, used only for the fire-and-forget POST
# /api/usage/log after each successful /browse call. Override for
# docker-compose (e.g. http://backend:3000) or a split deployment.
BACKEND_URL=http://127.0.0.1:3000
