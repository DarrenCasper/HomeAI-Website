# Ollama model the browsing agent's own LLM uses to drive the browser.
BROWSER_AGENT_MODEL=qwen2.5:7b

# Hard wall-clock cap per /browse task (seconds), independent of max_steps.
BROWSER_AGENT_TIMEOUT_S=90

# Leave false: blocks navigation to literal IP addresses (covers RFC1918,
# loopback, 169.254.0.0/16) and to localhost/*.local/*.internal/*.lan/*.ts.net,
# so a prompt-injected page can't redirect the agent at this homelab or its
# tailnet. Only set true for deliberate local testing.
BROWSER_AGENT_ALLOW_PRIVATE_NET=false
