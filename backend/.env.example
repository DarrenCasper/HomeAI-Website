DATABASE_URL=postgres://user:password@localhost:5432/homelab_ai
MONGODB_URI=mongodb://localhost:27017/homelab_ai

# Backend -> browsing-agent (src/lib/browsingAgent.js), used by POST /api/chat
# when the model supports tool-calling (src/utils/modelMode.js supportsTools)
# and decides to call browse_web. BROWSER_AGENT_MODEL, _TIMEOUT_S and
# _ALLOW_PRIVATE_NET configure the browsing-agent service itself, not this
# backend - set them in browsing-agent/.env instead.
BROWSER_AGENT_URL=http://127.0.0.1:8001

# Backend -> voice-agent (src/routes/voice.js), which proxies
# POST /api/voice/transcribe and /speak straight through. WHISPER_* and
# PIPER_VOICE_PATH configure the voice-agent service itself, not this
# backend - set them in voice-agent/.env instead.
VOICE_AGENT_URL=http://127.0.0.1:8002

# POST /api/vision (src/routes/vision.js) describes a shared screenshot via
# OpenAI first (src/lib/openaiVision.js) - same key as browsing-agent's
# OPENAI_API_KEY, set once here. VISION_MODEL is the local Ollama model used
# only as a fallback when OpenAI is unreachable or OPENAI_API_KEY is unset.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
VISION_MODEL=qwen2.5vl:7b

# Per-user monthly cap (src/lib/usageCap.js) on the two OpenAI-billed
# features - vision (src/routes/vision.js) and the browse_web tool
# (src/routes/chat.js) - checked before the OpenAI-costing call, not after.
# search_documents isn't gated by this - it only costs a local Ollama
# embedding call, no OpenAI spend. Default $1.00/user/month assumes a
# shared ~$5/month OpenAI budget across ~5-6 people actually using these
# features; tune to the real budget/headcount.
USER_MONTHLY_CAP_USD=1.00

# POST /api/documents/upload (src/routes/documents.js) chunks and embeds
# uploaded text/markdown/PDF notes via Ollama's /api/embed
# (src/lib/embeddings.js) so POST /api/chat's search_documents tool can
# retrieve them later. Requires `ollama pull nomic-embed-text` on whichever
# host OLLAMA_URL below points at - no separate env var, same host as chat.

# Comma-separated list of origins allowed to call this API cross-origin (the
# frontend is a static build with no reverse proxy in front of it). Defaults
# to the production frontend + local Vite dev if unset.
CORS_ORIGIN=https://homeai.darrencasper.com,http://localhost:5173

# POST /api/chat picks its response mode AND Ollama keep_alive from the model
# name automatically (src/utils/modelMode.js) - none of this needs an env var
# to work, the vars below are just optional overrides:
#   - name contains "qwen" -> streamed response (avoids the Cloudflare ~100s
#                             proxy timeout); kept warm 30m (OLLAMA_KEEP_ALIVE_QWEN)
#   - anything else        -> streamed response, 5m keep_alive
#                             (OLLAMA_KEEP_ALIVE_DEFAULT)
# The background job + polling path (GET /api/chat/jobs/:jobId) stays
# available as reusable machinery for any future model slow enough to need
# it - nothing currently routes to it.
# OLLAMA_URL is the Nitro 7's (GPU) Tailscale IP - the primary host for
# ollamaChat/ollamaChatStream (src/lib/ollama.js). If it's unreachable, chat
# requests automatically fail over to OLLAMA_FALLBACK_URL (this machine's own
# local Ollama) using the tiny CPU-friendly model tags in
# OLLAMA_FALLBACK_MODEL_MAP instead of the normal ones - see
# resolveOllamaTarget() for the reachability-check/caching behavior.
# ollamaVisionChat (vision fallback) always uses OLLAMA_URL directly, no
# failover - it's already the fallback for OpenAI vision, not worth a second
# layer of fallback behind it.
OLLAMA_URL=http://100.x.x.x:11434
OLLAMA_FALLBACK_URL=http://127.0.0.1:11434
OLLAMA_FALLBACK_MODEL_MAP={"qwen3.5:4b":"qwen3.5:0.8b"}
OLLAMA_PRIMARY_TIMEOUT_MS=3000
OLLAMA_KEEP_ALIVE_QWEN=30m
OLLAMA_KEEP_ALIVE_DEFAULT=5m
PORT=3000

# Only used when no Tailscale-User-Login header is present (local dev without
# tailscale serve in front). Leave unset in production.
DEV_FALLBACK_USER=

# Email/password accounts (src/routes/auth.js): identity is Tailscale header
# > session cookie > DEV_FALLBACK_USER, in that order - all three log in the
# same way against history/chat, req.userId is just the email either way.
# Session cookies only get the Secure flag when NODE_ENV=production (already
# set in Dockerfile), so local http dev still works without it.
NODE_ENV=development
