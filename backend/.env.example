DATABASE_URL=postgres://user:password@localhost:5432/homelab_ai
MONGODB_URI=mongodb://localhost:27017/homelab_ai

# Comma-separated list of origins allowed to call this API cross-origin (the
# frontend is a static build with no reverse proxy in front of it). Defaults
# to the production frontend + local Vite dev if unset.
CORS_ORIGIN=https://homeai.darrencasper.com,http://localhost:5173

# POST /api/chat picks its response mode from the model name automatically
# (src/utils/modelMode.js) - no env var needed:
#   - name contains "qwen"              -> streamed response (avoids the
#                                           Cloudflare ~100s proxy timeout)
#   - name contains "deepseek"/"deepsek" -> background job, poll
#                                           GET /api/chat/jobs/:jobId
#   - anything else                      -> streamed response (default)
OLLAMA_URL=http://127.0.0.1:11434
PORT=3000

# Only used when no Tailscale-User-Login header is present (local dev without
# tailscale serve in front). Leave unset in production.
DEV_FALLBACK_USER=
